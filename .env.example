WE_MP_RSS_API_BASE=/api/v1/wx
WE_MP_RSS_ACCESS_KEY=
WE_MP_RSS_SECRET_KEY=
FEISHU_PROVIDER=auto
FEISHU_CLI_PATH=lark-cli
FEISHU_CLI_AS=user
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_POSTER_ATTACHMENT_FIELD=海报附件
FEISHU_ACTIVITY_KIND_FIELD=活动类型
FEISHU_ACTIVITY_KIND_CODE_FIELD=活动类型编码
