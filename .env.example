# 日报/周报配置
FEISHU_REPORT_CHAT_ID=
FEISHU_REPORT_USER_ID=
FEISHU_REPORT_DAILY_CRON=0 9 * * *
FEISHU_REPORT_WEEKLY_CRON=0 9 * * 1
FEISHU_REPORT_DAILY_ENABLED=true
FEISHU_REPORT_WEEKLY_ENABLED=true

# 自动同步配置（cron 表达式，默认每小时同步一次）
AUTO_SYNC_CRON=0 * * * *
